#!/bin/sh
echo "Sprawdzanie błędów TypeScript..."
BUILD_OUTPUT=$(npm run build 2>&1)
BUILD_EXIT_CODE=$?

if [ $BUILD_EXIT_CODE -ne 0 ]; then
  echo "$BUILD_OUTPUT" | grep -i "Type error" && {
    echo "BŁĄD: Znaleziono błędy TypeScript - commit zablokowany"
    exit 1
  }
fi

echo "OK - brak błędów TypeScript"
exit 0
