# Database — MySQL connection string
# Example: mysql://USER:PASSWORD@HOST:3306/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/pos_karczma"

# Redis — required for rate limiting and caching
# Example: redis://localhost:6379 or redis://:password@host:6379
REDIS_URL="redis://localhost:6379"

# E-receipt SMS (SMSAPI.pl) — optional, demo mode if not set
SMSAPI_TOKEN=""
SMSAPI_SENDER="Karczma"

# App URL for e-receipt links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# JWT secret for session tokens (REQUIRED - minimum 32 characters)
JWT_SECRET="your-secret-key-min-32-chars-here"

# Server URLs for connection failover (PWA/mobile)
NEXT_PUBLIC_MAIN_SERVER_URL="https://pos.karczma-labedz.pl"
NEXT_PUBLIC_LOCAL_SERVER_URL="http://10.119.169.20:3001"

# Connection monitoring settings (milliseconds)
NEXT_PUBLIC_CONNECTION_CHECK_INTERVAL="30000"
NEXT_PUBLIC_REDIRECT_DELAY="5000"
