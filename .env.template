# =============================================================================
# POS Karczma - Szablon konfiguracji środowiska
# =============================================================================
# Ten plik jest automatycznie kopiowany do .env przy pierwszym uruchomieniu.
# Możesz go edytować według potrzeb - .env NIE jest commitowany do Git.
# =============================================================================

# Database — MySQL/MariaDB connection string
# connection_limit=10 - pula połączeń, pool_timeout=5 - max czas oczekiwania
DATABASE_URL=mysql://bistro_sync:sync123@127.0.0.1:3306/pos_karczma?connection_limit=10&pool_timeout=5&connect_timeout=5

# Redis cache (optional - znacząco poprawia wydajność API)
# Uruchom Redis: docker run -d -p 6379:6379 redis:alpine
REDIS_URL="redis://localhost:6379"

# E-receipt SMS (SMSAPI.pl) — opcjonalne, tryb demo jeśli puste
SMSAPI_TOKEN=""
SMSAPI_SENDER="Karczma"

# App URL for e-receipt links
NEXT_PUBLIC_APP_URL="https://pos.karczma-labedz.pl"

# JWT secret for session tokens (zmień na produkcji!)
JWT_SECRET="pos-karczma-jwt-secret-key-32chars"

# Server URLs for connection failover (PWA/mobile)
NEXT_PUBLIC_MAIN_SERVER_URL="https://pos.karczma-labedz.pl"
NEXT_PUBLIC_LOCAL_SERVER_URL="http://10.119.169.20:3001"

# Connection monitoring settings (milliseconds)
# Zmniejsz CONNECTION_CHECK_INTERVAL do 15000 dla częstszego sprawdzania
NEXT_PUBLIC_CONNECTION_CHECK_INTERVAL="30000"
NEXT_PUBLIC_REDIRECT_DELAY="5000"
