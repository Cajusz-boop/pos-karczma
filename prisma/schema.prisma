// POS Karczma Łabędź — full schema from PRD
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "mysql"
  // URL in prisma.config.ts (Prisma 7)
}

// ============================================================
// FOUNDATION
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String
  pin           String    @unique // 4-digit, hashed
  role          Role      @relation(fields: [roleId], references: [id])
  roleId        String
  authMethod    AuthMethod @default(PIN)
  tokenId       String?   @unique // NFC UID, barcode, card number
  tokenType     TokenType? // NFC, BARCODE, CARD
  isActive      Boolean   @default(true)
  isOwner       Boolean   @default(false)
  expiresAt     DateTime? // pracownik sezonowy
  createdAt     DateTime  @default(now())

  pinBistroMo   String?   // osobny PIN dla BistroMo
  autoLogoutSec Int?      // auto wyloguj po N sekundach bezczynności (null=domyślny)
  allowedCategoryIds  Json? // [] = wszystkie, lista ID kategorii
  allowedTableIds     Json? // [] = wszystkie, lista ID stolików
  allowedPriceLevelIds Json? // [] = wszystkie, poziomy cenowe
  uiButtonGroups      Json? // konfiguracja 6 grup przycisków F4
  permissionsJson     Json? // szczegółowe uprawnienia wg zakładek

  orders        Order[]
  shifts        Shift[]
  tips          Tip[]
  auditLogs     AuditLog[]
  cashOperations CashOperation[]
  timeEntries   TimeEntry[]
  soldVouchers  GiftVoucher[]
  workSchedules   WorkSchedule[]
  availability    StaffAvailability[]
  swapRequests    ShiftSwapRequest[] @relation("SwapRequester")
  swapTargets     ShiftSwapRequest[] @relation("SwapTarget")
  announcements   Announcement[]
  deliveryDriver  DeliveryDriver?
}

enum AuthMethod {
  PIN
  NFC
  BARCODE
  CARD
}

enum TokenType {
  NFC
  BARCODE
  CARD
  MAGNETIC_COM     // magnetic card reader via COM port
  MAGNETIC_USB     // magnetic card reader USB wedge
  RFID_CLAMSHELL   // RFID Clamshell/Unique 19200 8N1
  DALLAS_DATAPROCESS
  DALLAS_DEMIURG
  DALLAS_JARLTECH
  DALLAS_MP00202
  FILE_READER      // code from file (external program)
}

model CardReaderConfig {
  id          String @id @default(cuid())
  name        String
  type        TokenType
  comPort     String?     // COM1, COM2, etc.
  baudRate    Int?        // 9600, 19200
  dataBits    Int?        // 7, 8
  stopBits    Int?        // 1, 2
  parity      String?     // none, odd, even
  filePath    String?     // for FILE_READER type
  isActive    Boolean @default(true)
  workstationId String?   // assigned to specific workstation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique // ADMIN, WAITER
  permissions Json     // string[] of permission keys
  users       User[]
}

// ============================================================
// ROOMS & TABLES
// ============================================================

model Room {
  id            String    @id @default(cuid())
  name          String    // "Restauracja", "Sala Złota", etc.
  capacity      Int
  type          RoomType
  isSeasonal    Boolean   @default(false)
  isActive      Boolean   @default(true)
  canMergeWith  Json      @default("[]") // room IDs that can merge (JSON array)
  layoutJson    Json?     // {tables: [{id, x, y, shape, seats}]}
  sortOrder     Int       @default(0)

  backgroundImage String? // URL to custom background image
  backgroundOpacity Float @default(1.0)
  decorElements   Json    @default("[]") // [{type, x, y, w, h, rotation, image}]

  tables        Table[]
  reservations  Reservation[]
  banquetEvents BanquetEvent[]
  orders        Order[]

  @@map("room")
}

enum RoomType {
  RESTAURANT
  BANQUET
  OUTDOOR
  PRIVATE
}

model RoomMerge {
  id          String   @id @default(cuid())
  roomIds     Json     // IDs of merged rooms (JSON array)
  mergedName  String   // "Bankiet Połączony"
  isActive    Boolean  @default(true)
  activeFrom  DateTime
  activeTo    DateTime?

  @@map("roommerge")
}

model Table {
  id             String      @id @default(cuid())
  room           Room        @relation(fields: [roomId], references: [id])
  roomId         String
  number         Int
  seats          Int
  positionX      Float       @default(0)
  positionY      Float       @default(0)
  width          Float       @default(80)
  height         Float       @default(80)
  rotation       Int         @default(0) // 0, 90, 180, 270 degrees
  zIndex         Int         @default(0) // layer order
  shape          TableShape  @default(RECTANGLE)
  status         TableStatus @default(FREE)
  assignedUser   String?     // user ID
  needsAttention Boolean     @default(false) // flaga "wymaga uwagi" dla kelnera

  description    String?     // "Przy kominku", "VIP"
  isAvailable    Boolean     @default(true) // false = szary, niedostępny
  allowMultipleOrders Boolean @default(false) // dwa zamówienia na stoliku
  customColor    String?     // hex color override
  qrId           String?     @unique // UUID v4 — identyfikator kodu QR (null = brak QR)

  orders        Order[]
  reservations  Reservation[]

  @@index([roomId, status])
  @@map("table")
}

enum TableShape {
  RECTANGLE
  ROUND
  LONG // bankietowy
}

enum TableStatus {
  FREE
  OCCUPIED
  BILL_REQUESTED
  RESERVED
  BANQUET_MODE
  INACTIVE
}

// ============================================================
// PRODUCTS & MENU
// ============================================================

model Category {
  id          String    @id @default(cuid())
  name        String
  parentId    String?
  parent      Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  sortOrder   Int       @default(0)
  color       String?   // hex color for POS button
  icon        String?
  imageUrl    String?   // URL to category image/photo
  isActive    Boolean   @default(true)
  isSeasonal  Boolean   @default(false)
  seasonStart DateTime? // when seasonal category becomes visible
  seasonEnd   DateTime? // when seasonal category hides

  products  Product[]
  kdsStations KDSStationCategory[]
  printerAssignments PrinterCategory[]

  @@index([parentId, sortOrder])
  @@index([isActive])
}

model Product {
  id              String    @id @default(cuid())
  name            String    // max 40 chars (Posnet limit)
  nameShort       String?   // abbreviated for receipt
  category        Category  @relation(fields: [categoryId], references: [id])
  categoryId      String
  priceGross      Decimal   @db.Decimal(10, 2)
  costPrice       Decimal?  @db.Decimal(10, 2) // food cost per portion
  taxRate         TaxRate   @relation(fields: [taxRateId], references: [id])
  taxRateId       String
  isActive        Boolean   @default(true)
  isAvailable     Boolean   @default(true) // 86 board
  estimatedPrepMinutes Int? // estimated preparation time in minutes
  sortOrder       Int       @default(0)
  color           String?
  imageUrl        String?
  recipe          Recipe?
  isWeightBased   Boolean   @default(false) // sold by weight (kg, g)
  requiresWeightConfirm Boolean @default(false) // needs weight confirmation after preparation
  unit            String?   // "kg", "g", "szt", "l"
  tareWeight      Decimal?  @db.Decimal(10, 3) // default tare for packaging

  productType     ProductType @default(REGULAR)
  isSet           Boolean   @default(false) // is this a combo/set
  setPriceMode    SetPriceMode? // how set price is calculated
  maxComponents   Int?      // max components in set (e.g., max 4 toppings)
  freeComponents  Int?      // first N components are free
  superGroupId    String?   // which super group this addon belongs to (for restricted addons)
  superGroup      SuperGroup? @relation(fields: [superGroupId], references: [id])

  isAddonOnly     Boolean   @default(false) // can only be added as addon, not standalone
  isHidden        Boolean   @default(false) // hidden from menu, only via sets
  noPrintKitchen  Boolean   @default(false) // don't print to kitchen (known ingredient)
  printWithMinus  Boolean   @default(false) // print "BRAK" when removed
  canRepeat       Boolean   @default(true)  // can appear multiple times in order
  alwaysOnePortion Boolean  @default(false) // always 1 portion, no quantity change
  noQuantityChange Boolean  @default(false) // block quantity changes after adding
  askForComponents Boolean  @default(false) // prompt for set components after adding

  afterSelectGoTo String?   // category ID to navigate to after selection
  afterSelectAction String? // action to perform (e.g., "openNotes")

  maxPerOrder     Int?      // max times this product can be ordered (e.g., 1 lunch per person)
  noGeneralDesc   Boolean   @default(false) // forbid general description on invoice
  isDefaultTemplate Boolean @default(false) // use as template for new products

  modifierGroups  ProductModifierGroup[]
  allergens       ProductAllergen[]
  orderItems      OrderItem[]
  suggestionsBase   ProductSuggestion[] @relation("SuggestionBase")
  suggestionsTarget ProductSuggestion[] @relation("SuggestionTarget")
  setComponents   SetComponent[] @relation("SetParent")
  componentOf     SetComponent[] @relation("SetChild")

  @@index([categoryId, isActive, isAvailable])
  @@index([isActive, sortOrder])
}

enum ProductType {
  REGULAR     // standard product
  SET         // combo/set with components
  HELPER_SET  // helper set - auto-adds components, not a line item
  ADDON       // addon only, restricted to super groups
  ADDON_GLOBAL // addon available everywhere
}

enum SetPriceMode {
  OWN_PRICE       // set has its own price, components don't add
  CALCULATED      // price = sum of component prices
  CALCULATED_SINGLE // calculated but appears as single line on receipt
}

model SuperGroup {
  id          String    @id @default(cuid())
  number      Int       @unique // 1-10
  name        String    // "Dodatki do pizzy", "Sosy do mięs"
  categoryIds Json      @default("[]") // which categories can use these addons
  isActive    Boolean   @default(true)

  products    Product[]
}

model SetComponent {
  id              String   @id @default(cuid())
  set             Product  @relation("SetParent", fields: [setId], references: [id], onDelete: Cascade)
  setId           String
  component       Product  @relation("SetChild", fields: [componentId], references: [id])
  componentId     String
  quantity        Decimal  @db.Decimal(10, 3) @default(1)
  isRequired      Boolean  @default(false)
  isDefault       Boolean  @default(true) // included by default
  priceDelta      Decimal  @db.Decimal(10, 2) @default(0) // extra price when added
  sortOrder       Int      @default(0)

  isHidden        Boolean  @default(false) // hidden in UI but affects stock
  noPrintKitchen  Boolean  @default(false) // don't print (cook knows)
  printWithMinus  Boolean  @default(false) // print "BRAK" when removed

  @@unique([setId, componentId])
  @@index([setId])
}

model TaxRate {
  id            String   @id @default(cuid())
  name          String   // "VAT 23%", "VAT 8%"
  ratePercent   Decimal  @db.Decimal(5, 2)
  fiscalSymbol  String   // A, B, C, D, E, F, G
  isDefault     Boolean  @default(false)

  products      Product[]
  orderItems    OrderItem[]

  @@map("taxrate")
}

model ModifierGroup {
  id          String    @id @default(cuid())
  name        String    // "Stopień wysmażenia"
  minSelect   Int       @default(0)
  maxSelect   Int       @default(1)
  isRequired  Boolean   @default(false)

  modifiers   Modifier[]
  products    ProductModifierGroup[]

  @@map("modifiergroup")
}

model Modifier {
  id          String        @id @default(cuid())
  name        String        // "medium rare"
  priceDelta  Decimal       @db.Decimal(10, 2) @default(0)
  group       ModifierGroup @relation(fields: [groupId], references: [id])
  groupId     String
  sortOrder   Int           @default(0)

  @@map("modifier")
}

model ProductModifierGroup {
  product         Product       @relation(fields: [productId], references: [id])
  productId       String
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id])
  modifierGroupId String

  @@id([productId, modifierGroupId])
  @@map("productmodifiergroup")
}

model Allergen {
  id    String @id @default(cuid())
  code  String @unique // "GLUTEN", "EGGS", etc.
  name  String         // "Gluten", "Jaja"
  icon  String?        // emoji or icon name

  products ProductAllergen[]

  @@map("allergen")
}

model ProductAllergen {
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  allergen   Allergen @relation(fields: [allergenId], references: [id])
  allergenId String

  @@id([productId, allergenId])
  @@map("productallergen")
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id              String      @id @default(cuid())
  orderNumber     Int         @default(1)
  table           Table?      @relation(fields: [tableId], references: [id])
  tableId         String?
  room            Room?       @relation(fields: [roomId], references: [id])
  roomId         String?
  user            User        @relation(fields: [userId], references: [id])
  userId          String
  customer        Customer?   @relation(fields: [customerId], references: [id])
  customerId      String?
  status          OrderStatus @default(OPEN)
  type            OrderType   @default(DINE_IN)
  guestCount      Int         @default(1)
  banquetEvent    BanquetEvent? @relation(fields: [banquetEventId], references: [id])
  banquetEventId  String?
  discountJson    Json?       // {type, value, reason, authorizedBy}
  note            String?
  courseReleasedUpTo Int       @default(1)
  // Delivery/phone order fields
  deliveryPhone   String?
  deliveryAddress String?
  deliveryStatus  DeliveryStatus?
  deliveryNote    String?
  estimatedAt     DateTime?   // estimated pickup/delivery time
  deliveryZone    DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  deliveryZoneId  String?
  assignedDriverId String?    // DeliveryDriver.id
  deliveryCost    Decimal?    @db.Decimal(10, 2) // actual delivery cost charged
  driverCommission Decimal?   @db.Decimal(10, 2) // commission for driver
  deliveredAt     DateTime?   // when order was delivered
  maxTotal        Decimal?    @db.Decimal(10, 2) // limit kwoty (poczęstunek firmowy)
  copiedFromId    String?     // original order ID if this is a copy
  closedButVisible Boolean    @default(false) // pozostaw po zamknięciu do podglądu
  createdAt       DateTime    @default(now())
  closedAt        DateTime?
  // Performance cache fields
  totalGross        Decimal     @db.Decimal(10, 2) @default(0) // cached sum of items
  itemCount         Int         @default(0)                     // cached count of items
  lastInteractionAt DateTime    @default(now())                 // last change timestamp
  onlinePaymentStatus OnlinePaymentStatus @default(UNPAID) // dla płatności QR

  items           OrderItem[]
  payments        Payment[]
  receipts        Receipt[]
  invoices        Invoice[]
  tips            Tip[]
  onlinePayments  OnlinePayment[]

  @@index([tableId, status])
  @@index([status, createdAt])
}

enum OrderStatus {
  OPEN
  SENT_TO_KITCHEN
  IN_PROGRESS
  READY
  SERVED
  BILL_REQUESTED
  CLOSED
  CANCELLED
}

enum OnlinePaymentStatus {
  UNPAID
  PARTIAL
  PENDING
  PAID
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  BANQUET
  PHONE
  DELIVERY
  HOTEL_ROOM
}

enum DeliveryStatus {
  PENDING
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

model OrderItem {
  id              String          @id @default(cuid())
  order           Order           @relation(fields: [orderId], references: [id])
  orderId         String
  product         Product         @relation(fields: [productId], references: [id])
  productId       String
  quantity        Decimal        @db.Decimal(10, 3) // allow fractional (wine by glass)
  unitPrice       Decimal        @db.Decimal(10, 2) // price at time of order
  taxRate         TaxRate        @relation(fields: [taxRateId], references: [id])
  taxRateId       String
  discountAmount  Decimal        @db.Decimal(10, 2) @default(0)
  modifiersJson   Json?          // [{modifierId, name, priceDelta}]
  note            String?        // "bez cebuli"
  courseNumber    Int            @default(1)
  status          OrderItemStatus @default(ORDERED)
  sentToKitchenAt DateTime?
  startedAt       DateTime?      // when cook clicked "Zaczynam" (IN_PROGRESS)
  preparedByUserId String?       // which cook prepared this item
  kdsStationId    String?        // which KDS station handled this item
  readyAt         DateTime?
  servedAt        DateTime?
  cancelledAt     DateTime?
  cancelReason    String?
  isBanquetExtra  Boolean        @default(false) // extra beyond banquet menu
  isModifiedAfterSend Boolean   @default(false) // żółte "ZMIANA" na KDS
  delayMinutes    Int?           // minutnik: opóźnienie startu przygotowania
  fireAt          DateTime?      // minutnik: kiedy rozpocząć (obliczone z delayMinutes)
  isFire          Boolean        @default(false) // "Ogień" - priorytet natychmiastowy
  firedAt         DateTime?      // kiedy kliknięto "Ogień"
  isTakeaway      Boolean        @default(false) // tylko ta pozycja na wynos
  requiresWeightConfirm Boolean  @default(false) // copied from product
  weightConfirmed Boolean        @default(false) // weight confirmed by kitchen
  confirmedWeight Decimal?       @db.Decimal(10, 3) // actual weight after preparation
  weightConfirmedAt DateTime?
  weightConfirmedBy String?      // userId who confirmed
  weightBarcodeScanned String?   // barcode from scale label if scanned

  parentItemId    String?        // for set components - links to parent set item
  isSetComponent  Boolean        @default(false) // is this a component of a set
  componentPriceDelta Decimal?   @db.Decimal(10, 2) // price change for this component
  removedComponentsJson Json?    // [{productId, name}] for removed default components
  addedComponentsJson Json?      // [{productId, name, price}] for extra added components

  noteType        NoteType?      // type of note/message
  isRush          Boolean        @default(false) // "Na ratunek" - expedited prep
  isPriority      Boolean        @default(false) // "Jako pierwsze" 
  printBold       Boolean        @default(false) // print in bold on kitchen printer
  paidQuantity    Decimal        @db.Decimal(10, 3) @default(0) // dla płatności QR
  lockedQuantity  Decimal        @db.Decimal(10, 3) @default(0) // lock w trakcie płatności

  createdAt       DateTime       @default(now())

  @@index([orderId, status])
  @@index([parentItemId])
  @@map("orderitem")
}

enum NoteType {
  STANDARD        // regular note
  ALLERGY         // allergy warning (red)
  MODIFICATION    // modification (yellow)
  RUSH            // rush order (orange)
}

enum OrderItemStatus {
  ORDERED
  SENT
  IN_PROGRESS
  READY
  SERVED
  CANCELLED
}

// ============================================================
// PAYMENTS
// ============================================================

model Payment {
  id              String        @id @default(cuid())
  order           Order         @relation(fields: [orderId], references: [id])
  orderId         String
  method          PaymentMethod
  amount          Decimal       @db.Decimal(10, 2)
  tipAmount       Decimal       @db.Decimal(10, 2) @default(0)
  transactionRef  String?       // terminal reference
  voucher         GiftVoucher?  @relation(fields: [voucherId], references: [id])
  voucherId       String?
  createdAt       DateTime      @default(now())

  @@index([orderId])
  @@index([createdAt])
  @@map("payment")
}

enum PaymentMethod {
  CASH
  CARD
  BLIK
  TRANSFER
  VOUCHER
  ROOM_CHARGE
}

model OnlinePayment {
  id              String    @id @default(cuid())
  order           Order     @relation(fields: [orderId], references: [id])
  orderId         String
  provider        String    // "STRIPE", "PAYU", "PRZELEWY24"
  transactionId   String?   @unique
  amount          Decimal   @db.Decimal(10, 2)   // kwota za pozycje (BEZ napiwku)
  tipAmount       Decimal   @db.Decimal(10, 2) @default(0)
  totalCharged    Decimal   @db.Decimal(10, 2)   // amount + tipAmount
  currency        String    @default("PLN")
  status          String    @default("PENDING")  // PENDING | SUCCESS | FAILED | REFUNDED | EXPIRED
  itemsJson       Json      // [{orderItemId, quantity, unitPrice, lineTotal, fiscalSymbol, name}]
  customerEmail   String?
  customerPhone   String?
  receiptToken    String?   @unique  // token do trwałego linku potwierdzenia
  providerResponse Json?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  expiresAt       DateTime? // timeout na lock (np. +15 min)

  @@index([orderId])
  @@index([status, createdAt])
}

model Tip {
  id        String   @id @default(cuid())
  order     Order    @relation(fields: [orderId], references: [id])
  orderId   String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  amount    Decimal  @db.Decimal(10, 2)
  method    PaymentMethod
  createdAt DateTime @default(now())
}

model Discount {
  id          String       @id @default(cuid())
  name        String
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2) // percent or amount
  maxPercent  Decimal?     @db.Decimal(5, 2)  // cap
  isActive    Boolean      @default(true)
  validFrom   DateTime?
  validTo     DateTime?
  createdAt   DateTime     @default(now())
}

enum DiscountType {
  PERCENT
  AMOUNT
  PROMO
}

model Promotion {
  id          String   @id @default(cuid())
  name        String   // "Happy Hour Piwa"
  type        String   // happy_hour, daily_special, combo
  rulesJson   Json     // {categoryId, productId, discountPercent, discountAmount, timeFrom, timeTo}
  daysOfWeek  Json     @default("[]") // 0=Sun, 1=Mon, ... 6=Sat (JSON array)
  isActive    Boolean  @default(true)
  validFrom   DateTime
  validTo     DateTime
}

// ============================================================
// INVOICES & FISCAL
// ============================================================

model Invoice {
  id                String        @id @default(cuid())
  invoiceNumber     String        @unique // FV/2026/02/0001
  type              InvoiceType
  order             Order?        @relation(fields: [orderId], references: [id])
  orderId           String?
  banquetEvent      BanquetEvent? @relation(fields: [banquetEventId], references: [id])
  banquetEventId    String?
  buyerNip          String?
  buyerName         String?
  buyerAddress      String?
  itemsJson         Json          // [{name, qty, unitPrice, netPrice, vatRate, vatAmount, grossPrice}]
  netTotal          Decimal       @db.Decimal(10, 2)
  vatTotal          Decimal       @db.Decimal(10, 2)
  grossTotal        Decimal       @db.Decimal(10, 2)
  paymentMethod     String?
  saleDate          DateTime
  issueDate         DateTime      @default(now())
  dueDate           DateTime?
  ksefRefNumber     String?
  ksefStatus        KsefStatus    @default(PENDING)
  ksefErrorMessage  String?       // szczegóły błędu przy REJECTED / OFFLINE
  relatedInvoiceId  String?       // for corrections/finals → original invoice
  correctionReason  String?
  createdAt         DateTime      @default(now())
}

enum InvoiceType {
  STANDARD
  ADVANCE       // zaliczkowa
  FINAL         // końcowa (po zaliczkach)
  CORRECTION    // korygująca
}

enum KsefStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
  OFFLINE_QUEUED
}

model Receipt {
  id              String    @id @default(cuid())
  order           Order     @relation(fields: [orderId], references: [id])
  orderId         String
  fiscalNumber    String    // from Posnet
  printerId       String
  buyerNip        String?   // NIP on receipt
  token           String    @unique @default(cuid()) // e-receipt access token
  customerPhone   String?   // phone for SMS delivery
  customerEmail   String?   // email delivery
  deliveryMethod  String?   // "SMS", "QR", "EMAIL", "PRINT"
  htmlContent     String?   @db.LongText // rendered e-receipt HTML
  viewedAt        DateTime? // when customer opened e-receipt
  expiresAt       DateTime? // link expiry (e.g. 30 days)
  printedAt       DateTime  @default(now())
}

// ============================================================
// WAREHOUSE
// ============================================================

model Warehouse {
  id    String        @id @default(cuid())
  name  String
  type  WarehouseType

  stockItems StockItem[]
  movesFrom  StockMove[] @relation("MoveFrom")
  movesTo    StockMove[] @relation("MoveTo")
}

enum WarehouseType {
  MAIN
  BAR
  KITCHEN
  COLD_STORAGE
}

model Ingredient {
  id              String      @id @default(cuid())
  name            String
  unit            String      // "kg", "l", "szt"
  category        String?
  defaultSupplier String?

  stockItems      StockItem[]
  recipeItems     RecipeItem[]
}

model StockItem {
  id                String    @id @default(cuid())
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id])
  warehouseId       String
  ingredient        Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId      String
  quantity          Decimal   @db.Decimal(10, 3)
  unit              String
  minQuantity       Decimal   @db.Decimal(10, 3) @default(0)
  lastDeliveryPrice Decimal?  @db.Decimal(10, 2)
  updatedAt         DateTime  @updatedAt

  @@unique([warehouseId, ingredientId])
}

model StockMove {
  id              String        @id @default(cuid())
  type            StockMoveType
  documentNumber  String?
  warehouseFrom   Warehouse?    @relation("MoveFrom", fields: [warehouseFromId], references: [id])
  warehouseFromId String?
  warehouseTo     Warehouse?    @relation("MoveTo", fields: [warehouseToId], references: [id])
  warehouseToId   String?
  itemsJson       Json          // [{ingredientId, quantity, unit, price}]
  note            String?
  userId          String
  createdAt       DateTime      @default(now())
}

enum StockMoveType {
  PZ  // Przyjęcie Zewnętrzne
  WZ  // Wydanie Zewnętrzne
  RW  // Rozchód Wewnętrzny
  MM  // Przesunięcie Międzymagazynowe
  INV // Inwentaryzacja
}

model Recipe {
  id        String       @id @default(cuid())
  product   Product      @relation(fields: [productId], references: [id])
  productId String       @unique
  yieldQty  Decimal      @db.Decimal(10, 3) @default(1)

  items     RecipeItem[]
}

model RecipeItem {
  id           String     @id @default(cuid())
  recipe       Recipe     @relation(fields: [recipeId], references: [id])
  recipeId     String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  ingredientId String
  quantity     Decimal    @db.Decimal(10, 3)
  unit         String
}

// ============================================================
// MODUŁ RECEPTUR v3 (szefowa kuchni, planowanie imprez)
// Słownik produktów + receptury + tagi + historia zmian
// Odmienne od Recipe/RecipeItem (Product->Ingredient dla magazynu)
// ============================================================

model RecipeProduct {
  id            Int       @id @default(autoincrement())
  name          String    @unique @db.VarChar(200)
  defaultUnit   String    @default("kg") @db.VarChar(20) @map("unit")
  mergedIntoId  Int?
  createdAt     DateTime  @default(now())

  mergedInto    RecipeProduct?  @relation("ProductMerge", fields: [mergedIntoId], references: [id])
  aliases       RecipeProduct[] @relation("ProductMerge")
  ingredients   RecipeDishIngredient[]
  stockMinimum  StockMinimum?

  @@map("products")
}

model UnitConversion {
  id       Int    @id @default(autoincrement())
  fromUnit String @db.VarChar(20)
  toUnit   String @db.VarChar(20)
  factor   Float

  @@unique([fromUnit, toUnit])
  @@map("unit_conversions")
}

model RecipeDish {
  id            Int           @id @default(autoincrement())
  recipeNumber  Int           @unique
  name          String        @db.VarChar(200)
  basePortions  Float         @default(1)
  portionUnit   String        @default("porcja") @db.VarChar(20)
  status        RecipeStatus  @default(AKTYWNA)
  notes         String?       @db.Text
  isArchived    Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  ingredients   RecipeDishIngredient[]
  recipeTags    RecipeDishTag[]
  history       RecipeHistory[]

  subRecipeOf      RecipeDishIngredient[] @relation("SubRecipes")
  eventPackageItems EventPackageItem[]

  @@map("recipes")
}

enum RecipeStatus {
  AKTYWNA
  ARCHIWALNA
}

model RecipeDishIngredient {
  id           Int           @id @default(autoincrement())
  recipeId     Int
  productId    Int?
  subRecipeId  Int?
  quantity     Float
  unit         String        @default("kg") @db.VarChar(20)
  sortOrder    Int           @default(0)

  recipe       RecipeDish    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product      RecipeProduct? @relation(fields: [productId], references: [id])
  subRecipe    RecipeDish?   @relation("SubRecipes", fields: [subRecipeId], references: [id])

  @@map("recipe_ingredients")
}

model RecipeTag {
  id         Int    @id @default(autoincrement())
  name       String @unique @db.VarChar(100)
  color      String @default("#6B7280") @db.VarChar(7)
  createdAt  DateTime @default(now())

  recipeDishes RecipeDishTag[]

  @@map("tags")
}

model RecipeDishTag {
  recipeId  Int
  tagId     Int

  recipe    RecipeDish @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag       RecipeTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recipeId, tagId])
  @@map("recipe_tags")
}

model RecipeHistory {
  id          Int      @id @default(autoincrement())
  recipeId    Int
  changedBy   String   @db.VarChar(100)
  changeNote  String?  @db.VarChar(500)
  snapshot    Json
  createdAt   DateTime @default(now())

  recipe      RecipeDish @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("recipe_history")
}

// ============================================================
// FAZA 2 — Kalkulator zapotrzebowania (pakiety menu, imprezy)
// EventPackage / EventPackageItem — relacja do Event w fazie 2A
// ============================================================

enum EventPackageType {
  WESELE
  CHRZCINY
  KOMUNIA
  URODZINY
  KONFERENCJA
  INNE
}

model EventPackage {
  id             Int              @id @default(autoincrement())
  name           String           @unique @db.VarChar(200)
  eventType      EventPackageType
  eventTypes     Json?            // opcjonalnie: typy imprez jako tablica (np. ["WESELE","POPRAWINY"])
  pricePerPerson Float?
  isActive       Boolean          @default(true)
  notes          String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  items    EventPackageItem[]
  events   Event[]
  calendarConfigs CalendarConfig[]

  @@map("event_packages")
}

model EventPackageItem {
  id                Int      @id @default(autoincrement())
  packageId         Int
  recipeDishId      Int
  portionsPerPerson Float    @default(1)
  notes             String?  @db.VarChar(200)
  sortOrder         Int      @default(0)

  package    EventPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  recipeDish RecipeDish   @relation(fields: [recipeDishId], references: [id])

  @@map("event_package_items")
}

model ProcurementCalculation {
  id           Int       @id @default(autoincrement())
  weekStart    DateTime
  weekEnd      DateTime
  calculatedAt DateTime @default(now())
  calculatedBy String   @db.VarChar(100)
  result       Json
  emailSentAt  DateTime?
  emailSentTo  String?   @db.VarChar(200)

  @@map("procurement_calculations")
}

model StockMinimum {
  id        Int      @id @default(autoincrement())
  productId Int      @unique
  minimum   Float
  unit      String   @db.VarChar(20)
  updatedAt DateTime @updatedAt

  product RecipeProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("stock_minimums")
}

// ============================================================
// FAZA 2A — Google Calendar (imprezy)
// ============================================================

enum EventType {
  WESELE
  POPRAWINY
  CHRZCINY
  KOMUNIA
  URODZINY_ROCZNICA
  STYPA
  IMPREZA_FIRMOWA
  CATERING
  SPOTKANIE
  SYLWESTER
  INNE
}

enum EventStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum GuestCountSource {
  PARSED
  MANUAL
}

model Event {
  id               Int              @id @default(autoincrement())
  googleEventId    String           @unique @db.VarChar(200)
  googleCalendarId String           @db.VarChar(200)
  calendarName     String           @db.VarChar(100)
  eventType        EventType
  title            String           @db.VarChar(500)
  description      String?          @db.Text
  googleEventUrl   String?          @db.VarChar(500)
  startDate        DateTime
  endDate          DateTime
  roomName         String?          @db.VarChar(100)
  guestCount       Int?
  guestCountSource GuestCountSource @default(MANUAL)
  packageId        Int?
  notes            String?          @db.Text
  status           EventStatus      @default(DRAFT)
  syncedAt         DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  package EventPackage? @relation(fields: [packageId], references: [id])

  @@index([startDate])
  @@index([eventType])
  @@index([status])
  @@map("events")
}

model CalendarSyncLog {
  id              Int       @id @default(autoincrement())
  syncedAt        DateTime  @default(now())
  eventsAdded     Int       @default(0)
  eventsUpdated   Int       @default(0)
  eventsCancelled Int       @default(0)
  error           String?   @db.Text

  @@map("calendar_sync_log")
}

model CalendarConfig {
  id                Int           @id @default(autoincrement())
  calendarId        String        @unique @db.VarChar(200)
  calendarName      String        @db.VarChar(100)
  eventType         EventType
  roomName          String?       @db.VarChar(100)
  defaultPackageId  Int?
  isActive          Boolean       @default(true)

  defaultPackage EventPackage? @relation(fields: [defaultPackageId], references: [id])

  @@map("calendar_config")
}

// ============================================================
// KDS (Kitchen Display)
// ============================================================

model KDSStation {
  id           String @id @default(cuid())
  name         String // "Kuchnia Ciepła", "Bar"
  displayOrder Int    @default(0)

  showTableNumber    Boolean @default(true)
  showOrderNumber    Boolean @default(true)
  showWaiterName     Boolean @default(true)
  showDescription    Boolean @default(false)

  autoScrollNew      Boolean @default(true)  // auto-scroll to new orders
  confirmBeforeStatus Boolean @default(false) // ask before status change
  requireAllConfirm  Boolean @default(false) // require all items confirmed before course complete
  removeOnConfirm    Boolean @default(true)  // remove from view when confirmed

  udpBroadcast       Boolean @default(false) // send to UDP 3001
  udpHost            String? // target host for UDP
  udpPort            Int?    // target port (default 3001)

  categories KDSStationCategory[]
  archivedOrders KDSOrderArchive[]
}

model KDSOrderArchive {
  id              String   @id @default(cuid())
  station         KDSStation @relation(fields: [stationId], references: [id])
  stationId       String
  orderId         String
  orderNumber     Int
  tableNumber     Int?
  waiterName      String?
  itemsJson       Json     // snapshot of items
  receivedAt      DateTime
  completedAt     DateTime
  totalPrepTime   Int      // seconds from received to completed
  createdAt       DateTime @default(now())

  @@index([stationId, createdAt])
  @@index([orderId])
}

model KDSStationCategory {
  station    KDSStation @relation(fields: [stationId], references: [id])
  stationId  String
  category   Category   @relation(fields: [categoryId], references: [id])
  categoryId String

  @@id([stationId, categoryId])
}

model KDSLoadSnapshot {
  id          String   @id @default(cuid())
  stationId   String?
  pendingCount Int     @default(0)
  inProgressCount Int  @default(0)
  readyCount  Int      @default(0)
  totalActive Int      @default(0)
  timestamp   DateTime @default(now())

  @@index([timestamp])
  @@index([stationId, timestamp])
}

model KitchenMessage {
  id        String    @id @default(cuid())
  orderId   String?
  tableId   String?
  message  String
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

model CustomerDisplay {
  id          String  @id @default(cuid())
  name        String  // "Ekran TV przy barze"
  isActive    Boolean @default(true)
  showLogo    Boolean @default(true)
  logoUrl     String?
  backgroundColor String @default("#1a1a2e")
  textColor   String @default("#ffffff")
  accentColor String @default("#e94560")
  fontSize    Int     @default(48) // base font size in px
  maxOrders   Int     @default(10) // max orders to show
  showPreparingSection Boolean @default(true)
  showReadySection     Boolean @default(true)
  readyTimeoutSec      Int     @default(120) // remove ready after N seconds
  soundOnReady         Boolean @default(true)
  soundUrl             String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// PRINTERS
// ============================================================

model Printer {
  id             String      @id @default(cuid())
  name           String
  type           PrinterType
  connectionType String      // USB, COM, TCP
  address        String?     // IP or port path
  port           Int?
  model          String?     // "Posnet Thermal"
  isActive       Boolean     @default(true)
  charsPerLine   Int         @default(42)  // max znaków w linii
  codePage       String?     // "CP852", "UTF-8"
  cutAfterPrint  Boolean     @default(true)
  openDrawer     Boolean     @default(false) // otwórz szufladę po wydruku

  templatesJson  Json?       // szablony: {header, footer, item, storno, addon, set, component, course, timer, fire}
  remoteServer   String?     // adres comserwer.exe dla zdalnej drukarki

  categoryAssignments PrinterCategory[]
  printLogs      PrintLog[]
}

enum PrinterType {
  FISCAL
  KITCHEN
  BAR
  SYSTEM
}

model PrinterCategory {
  printer    Printer  @relation(fields: [printerId], references: [id])
  printerId  String
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  @@id([printerId, categoryId])
  @@map("printercategory")
}

model PrintLog {
  id          String    @id @default(cuid())
  printer     Printer   @relation(fields: [printerId], references: [id])
  printerId   String
  printType   PrintType
  orderId     String?
  orderNumber Int?
  contentJson Json      // treść wydruku
  status      PrintStatus @default(PENDING)
  errorMessage String?
  userId      String?
  createdAt   DateTime  @default(now())
  printedAt   DateTime?

  @@index([printerId, createdAt])
  @@index([orderId])
}

enum PrintType {
  KITCHEN_ORDER   // bon kuchenny
  KITCHEN_STORNO  // storno pozycji
  KITCHEN_CHANGE  // zmiana w zamówieniu
  RECEIPT         // paragon
  INVOICE         // faktura
  REPORT          // raport
  TEST            // wydruk testowy
}

enum PrintStatus {
  PENDING
  PRINTING
  PRINTED
  FAILED
}

// ============================================================
// RESERVATIONS & BANQUETS
// ============================================================

model Reservation {
  id          String            @id @default(cuid())
  room        Room              @relation(fields: [roomId], references: [id])
  roomId      String
  table       Table?            @relation(fields: [tableId], references: [id])
  tableId     String?
  date        DateTime          @db.Date
  timeFrom    DateTime
  timeTo      DateTime?
  guestName   String
  guestPhone  String?
  guestEmail  String?
  guestCount  Int
  type        ReservationType   @default(TABLE)
  notes       String?
  status      ReservationStatus @default(PENDING)
  source      ReservationSource @default(PHONE)
  createdAt   DateTime          @default(now())

  banquetEvent BanquetEvent?
  @@map("reservation")
}

enum ReservationType {
  TABLE
  BANQUET
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  COMPLETED
}

enum ReservationSource {
  PHONE
  ONLINE
  WALK_IN
}

model BanquetEvent {
  id              String              @id @default(cuid())
  reservation     Reservation         @relation(fields: [reservationId], references: [id])
  reservationId   String              @unique
  rooms           Room[]
  eventType       BanquetEventType
  guestCount      Int
  menu            BanquetMenu?        @relation(fields: [menuId], references: [id])
  menuId          String?
  pricePerPerson  Decimal             @db.Decimal(10, 2)
  extrasJson      Json?               // {openBar: bool, openBarLimit: number, dj: bool, decorations: string}
  depositRequired Decimal             @db.Decimal(10, 2) @default(0)
  depositPaid     Decimal             @db.Decimal(10, 2) @default(0)
  depositMethod   String?
  contactPerson   String
  contactPhone    String
  contactEmail    String?
  notes           String?
  status          BanquetStatus       @default(INQUIRY)
  createdAt       DateTime            @default(now())

  orders          Order[]
  invoices        Invoice[]
  menuModifications BanquetMenuModification[]
}

enum BanquetEventType {
  WEDDING
  EIGHTEENTH
  CORPORATE
  COMMUNION
  CHRISTENING
  FUNERAL
  OTHER
}

enum BanquetStatus {
  INQUIRY
  CONFIRMED
  DEPOSIT_PAID
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model BanquetMenu {
  id              String    @id @default(cuid())
  name            String    // "Menu Weselne Premium"
  eventType       String?
  itemsJson       Json      // [{productId, name, quantity, courseNumber}]
  pricePerPerson Decimal   @db.Decimal(10, 2)
  isTemplate      Boolean   @default(true)

  events          BanquetEvent[]
}

model BanquetMenuModification {
  id              String       @id @default(cuid())
  banquetEvent   BanquetEvent @relation(fields: [banquetEventId], references: [id])
  banquetEventId String
  changesJson     Json         // {substitutions: [{from, to, count}], additions: [], removals: []}
  priceAdjustment Decimal     @db.Decimal(10, 2) @default(0)
  note            String?
  createdAt       DateTime     @default(now())
}

// ============================================================
// SHIFTS & CASH
// ============================================================

model Shift {
  id        String      @id @default(cuid())
  user      User        @relation(fields: [userId], references: [id])
  userId    String
  startedAt DateTime   @default(now())
  endedAt   DateTime?
  cashStart Decimal     @db.Decimal(10, 2) @default(0)
  cashEnd   Decimal?    @db.Decimal(10, 2)
  status    ShiftStatus @default(OPEN)

  @@index([userId, status])
  @@index([startedAt])
}

enum ShiftStatus {
  OPEN
  CLOSED
}

model CashDrawer {
  id            String   @id @default(cuid())
  currentAmount Decimal  @db.Decimal(10, 2) @default(0)
  lastOpenedAt  DateTime?
  lastCountedAt DateTime?
}

model CashOperation {
  id        String             @id @default(cuid())
  type      CashOperationType
  amount    Decimal            @db.Decimal(10, 2)
  reason    String
  user      User               @relation(fields: [userId], references: [id])
  userId    String
  createdAt DateTime           @default(now())
}

enum CashOperationType {
  DEPOSIT
  WITHDRAWAL
}

// ============================================================
// AUDIT & REPORTING
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  action      String   // "ORDER_CANCEL", "DISCOUNT_APPLIED", "CASH_DRAWER_OPEN", etc.
  entityType  String   // "Order", "OrderItem", "Payment", etc.
  entityId    String?
  oldValue    Json?
  newValue    Json?
  metadata    Json?    // {reason, authorizedBy, ipAddress}
  timestamp   DateTime @default(now())

  @@map("auditlog")
}

model DailyReport {
  id                  String   @id @default(cuid())
  date                DateTime @db.Date @unique
  totalGross          Decimal  @db.Decimal(10, 2)
  totalNet            Decimal  @db.Decimal(10, 2)
  vatBreakdownJson    Json     // {A: {net, vat, gross}, B: {...}}
  paymentBreakdownJson Json    // {cash: x, card: y, blik: z, transfer: w}
  receiptCount        Int
  invoiceCount        Int
  guestCount          Int
  avgTicket           Decimal  @db.Decimal(10, 2)
  cancelCount         Int      @default(0)
  cancelAmount        Decimal  @db.Decimal(10, 2) @default(0)
  generatedAt         DateTime @default(now())
}

model ExportBatch {
  id        String   @id @default(cuid())
  type      String   // "daily", "monthly", "vat", "banquets"
  dateFrom  DateTime
  dateTo    DateTime
  filePath  String
  createdAt DateTime @default(now())
}

// ============================================================
// PUSH NOTIFICATIONS
// ============================================================

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String    // ORDER_READY, KITCHEN_MESSAGE, SHIFT_REMINDER, etc.
  entityId  String?   // related entity (orderId, etc.)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model PushSubscription {
  id          String   @id @default(cuid())
  userId      String
  endpoint    String   @db.Text
  p256dh      String   @db.Text
  auth        String
  createdAt   DateTime @default(now())

  @@unique([userId, endpoint(length: 255)])
  @@index([userId])
}

// ============================================================
// DELIVERY ZONES & DRIVERS
// ============================================================

model DeliveryZone {
  id              String   @id @default(cuid())
  number          Int      @unique // zone number (1, 2, 3...)
  name            String   // "Centrum", "Obrzeża miasta"
  driverCommission Decimal @db.Decimal(10, 2) @default(0) // commission per delivery
  deliveryCost    Decimal  @db.Decimal(10, 2) @default(0) // cost added to order
  minOrderForFreeDelivery Decimal? @db.Decimal(10, 2) // minimum order for free delivery
  estimatedMinutes Int     @default(30) // estimated delivery time in minutes
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  streets         DeliveryStreet[]
  orders          Order[]
}

model DeliveryStreet {
  id          String       @id @default(cuid())
  zone        DeliveryZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  zoneId      String
  streetName  String
  numberFrom  Int?         // optional range
  numberTo    Int?
  postalCode  String?
  city        String?

  @@index([streetName])
  @@index([zoneId])
}

model DeliveryDriver {
  id              String   @id @default(cuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String   @unique
  vehicleType     String?  // "car", "bike", "scooter"
  vehiclePlate    String?
  phoneNumber     String?
  isAvailable     Boolean  @default(true)
  currentOrderId  String?  // currently assigned order
  createdAt       DateTime @default(now())

  settlements     DriverSettlement[]
}

model DriverSettlement {
  id              String         @id @default(cuid())
  driver          DeliveryDriver @relation(fields: [driverId], references: [id])
  driverId        String
  shiftDate       DateTime       @db.Date
  totalDeliveries Int            @default(0)
  totalValue      Decimal        @db.Decimal(10, 2) @default(0)
  totalCommission Decimal        @db.Decimal(10, 2) @default(0)
  cashCollected   Decimal        @db.Decimal(10, 2) @default(0)
  status          SettlementStatus @default(PENDING)
  settledAt       DateTime?
  settledByUserId String?
  note            String?
  createdAt       DateTime       @default(now())

  @@unique([driverId, shiftDate])
  @@index([shiftDate])
}

enum SettlementStatus {
  PENDING
  SETTLED
  DISPUTED
}

// ============================================================
// SYSTEM CONFIG
// ============================================================

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  @@map("systemconfig")
}

model WorkstationConfig {
  id                  String  @id @default(cuid())
  name                String  @unique // "POS1", "BAR", "KUCHNIA"
  description         String?

  allowedCategoryIds  Json?   // które kategorie widoczne
  allowedRoomIds      Json?   // które sale widoczne
  defaultPriceLevelId String? // domyślny poziom cenowy
  defaultRoomId       String? // domyślna sala

  askQuantityRegular  Boolean @default(false) // pytaj o ilość (niewagowe)
  askQuantityWeighted Boolean @default(true)  // pytaj o ilość (wagowe)
  askPrice            Boolean @default(false) // pytaj o cenę
  askPriceManual      Boolean @default(true)  // pytaj o cenę (cena ręczna)

  autoSendKitchen     Boolean @default(false) // wyślij do kuchni bez pytania
  autoLogoutOnChange  Boolean @default(false) // zmiana operatora = wyjście
  refreshOnExit       Boolean @default(false) // odśwież bazę po wyjściu

  showOtherGroups     Boolean @default(true)  // pokaż grupę "inne"
  ordersOldestFirst   Boolean @default(true)  // kolejność rachunków
  showOnlyOwn         Boolean @default(false) // tylko zamówienia zalogowanego

  logoutOnOrderExit   Boolean @default(false) // wyloguj po wyjściu z zamówienia
  forceSelectWaiter   Boolean @default(false) // wymuszaj wybór kelnera
  mergeSimilarItems   Boolean @default(true)  // sumuj podobne pozycje
  askGuestCount       Boolean @default(false) // pytaj o ilość osób
  printKitchenOnPay   Boolean @default(false) // drukuj w kuchni przy płatności
  printOnEveryChange  Boolean @default(false) // drukuj natychmiast po zmianie
  fiscalWithShift     Boolean @default(false) // raport fiskalny z raportem zmiany
  invoiceWithGenDesc  String  @default("ask") // "always", "ask", "never"
  askFiscalize        Boolean @default(false) // pytaj czy fiskalizować
  confirmReceipt      Boolean @default(true)  // komunikat o zatwierdzeniu
  confirmKitchen      Boolean @default(true)  // komunikat o wysłaniu
  skipZeroInReports   Boolean @default(false) // nie drukuj zerowych
  askBeforePrint      Boolean @default(false) // pytaj czy drukować
  skipZeroOnReceipt   Boolean @default(false) // nie drukuj zerowych na paragonie
  receiptWithGenDesc  Boolean @default(false) // paragony z opisem ogólnym
  mergeBeforeFiscal   Boolean @default(true)  // sumuj przed fiskalizacją
  noStockUpdatePrint  Boolean @default(false) // nie aktualizuj stanów po wydruku
  autoProduction      Boolean @default(false) // produkcja na bieżąco (RW/PW)
  fiscalizeWhat       Json    @default("[\"receipt\", \"invoice\"]") // co fiskalizować
  stationNumber       Int?    // nr stanowiska dla raportów

  pluginOnEnter       String? // program po wejściu
  pluginOnExit        String? // program po wyjściu
  allowedWarehouseIds Json?   // które magazyny widoczne

  isActive            Boolean @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ============================================================
// CUSTOMERS (historia gości)
// ============================================================

model Customer {
  id              String    @id @default(cuid())
  phone           String    @unique
  name            String?
  email           String?
  notes           String?
  hotelGuestId    String?   @unique // synced from hotel system
  loyaltyPoints   Int       @default(0)
  totalSpent      Decimal   @db.Decimal(10, 2) @default(0)
  visitCount      Int       @default(0)
  lastVisit       DateTime?
  createdAt       DateTime  @default(now())

  orders              Order[]
  loyaltyTransactions LoyaltyTransaction[]
}

// ============================================================
// LOYALTY PROGRAM (program lojalnościowy)
// ============================================================

model LoyaltyTransaction {
  id          String    @id @default(cuid())
  customer    Customer  @relation(fields: [customerId], references: [id])
  customerId  String
  points      Int       // positive = earned, negative = redeemed
  type        LoyaltyTxType
  orderId     String?   // related order (if any)
  description String?
  createdAt   DateTime  @default(now())
}

enum LoyaltyTxType {
  EARNED      // points earned from purchase
  REDEEMED    // points used for reward
  ADJUSTMENT  // manual adjustment by admin
  EXPIRED     // points expired
}

model LoyaltyReward {
  id              String  @id @default(cuid())
  name            String  // "Kawa gratis", "Deser gratis", "10% rabatu"
  pointsCost      Int     // how many points to redeem
  rewardType      String  // FREE_PRODUCT, DISCOUNT_PERCENT, DISCOUNT_AMOUNT
  rewardValue     Decimal @db.Decimal(10, 2) @default(0) // discount value or 0 for free product
  productId       String? // if FREE_PRODUCT, which product
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
}

// ============================================================
// PRODUCT SUGGESTIONS (sprzedaż sugerowana)
// ============================================================

model ProductSuggestion {
  id            String   @id @default(cuid())
  product       Product  @relation("SuggestionBase", fields: [productId], references: [id])
  productId     String
  suggested     Product  @relation("SuggestionTarget", fields: [suggestedId], references: [id])
  suggestedId   String
  type          String   // "ADDON", "UPSELL", "CROSS_SELL"
  priority      Int      @default(0)
  note          String?  // notatka dla kelnera (tooltip)
  isActive      Boolean  @default(true)

  @@unique([productId, suggestedId])
  @@index([productId, isActive, priority])
  @@map("productsuggestion")
}

// ============================================================
// TIME TRACKING (rejestr czasu pracy)
// ============================================================

model TimeEntry {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  clockIn   DateTime  @default(now())
  clockOut  DateTime?
  breakMin  Int       @default(0) // break minutes
  note      String?
  createdAt DateTime  @default(now())
}

// ============================================================
// GIFT VOUCHERS (karty podarunkowe)
// ============================================================

model GiftVoucher {
  id            String    @id @default(cuid())
  code          String    @unique
  initialValue  Decimal   @db.Decimal(10, 2)
  balance       Decimal   @db.Decimal(10, 2)
  isActive      Boolean   @default(true)
  expiresAt     DateTime?
  soldByUser    User?     @relation(fields: [soldByUserId], references: [id])
  soldByUserId  String?
  customerName  String?   // who bought / who it's for
  note          String?
  createdAt     DateTime  @default(now())

  payments      Payment[]
}

// ============================================================
// WORK SCHEDULE (grafik pracy)
// ============================================================

model WorkSchedule {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  date      DateTime @db.Date
  shiftStart String  // "08:00"
  shiftEnd   String  // "16:00"
  role       String? // "Kelner", "Kucharz", "Bar"
  note       String?
  isConfirmed Boolean @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, date])
}

model StaffAvailability {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  date      DateTime @db.Date
  available Boolean  @default(true)
  timeFrom  String?  // "08:00" — available from
  timeTo    String?  // "22:00" — available until
  note      String?
  createdAt DateTime @default(now())

  @@unique([userId, date])
}

model ShiftSwapRequest {
  id            String   @id @default(cuid())
  requester     User     @relation("SwapRequester", fields: [requesterId], references: [id])
  requesterId   String
  target        User     @relation("SwapTarget", fields: [targetId], references: [id])
  targetId      String
  date          DateTime @db.Date
  status        SwapStatus @default(PENDING)
  reason        String?
  respondedAt   DateTime?
  createdAt     DateTime @default(now())
}

enum SwapStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

// ============================================================
// BULLETIN BOARD (tablica ogłoszeń)
// ============================================================

model Announcement {
  id        String    @id @default(cuid())
  author    User      @relation(fields: [authorId], references: [id])
  authorId  String
  title     String
  content   String    @db.Text
  priority  AnnouncementPriority @default(NORMAL)
  pinned    Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
}

// ============================================================
// POS UI MACROS & PREFERENCES
// ============================================================

model UserMacro {
  id          String    @id @default(cuid())
  userId      String
  slot        Int       // 1-5
  name        String    // "Lunch menu"
  actionsJson Json      // [{type: "addProduct", productId: "xxx"}, {type: "setQuantity", value: 2}]
  hotkey      String?   // "~1", "~2", etc.
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, slot])
  @@index([userId])
}

model UserPosPreference {
  id                String    @id @default(cuid())
  userId            String    @unique
  keyboardMode      Boolean   @default(false) // tryb klawiatury numerycznej
  t9Mode            Boolean   @default(false) // szukanie T9
  buttonRows        Int       @default(4)     // liczba rzędów przycisków (4-6)
  showPrices        Boolean   @default(true)  // pokazuj ceny na przyciskach
  showImages        Boolean   @default(false) // pokazuj obrazki produktów
  confirmQuantity   Boolean   @default(false) // potwierdzaj ilość po dodaniu
  autoPrintKitchen  Boolean   @default(true)  // automatyczny wydruk do kuchni
  soundEnabled      Boolean   @default(true)  // dźwięki interfejsu
  quickAmounts      Json?     // [0.25, 0.5, 1, 2, 5] szybkie ilości
  favoriteProducts  Json?     // [productId1, productId2] ulubione produkty
  recentProducts    Json?     // ostatnio używane (auto-aktualizowane)
  customColors      Json?     // {background, accent, text}
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("userpospreference")
}

// ============================================================
// PENDING PAYMENTS (płatności oczekujące - SoftPOS)
// ============================================================

model PendingPayment {
  id          String   @id
  orderId     String
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("PLN")
  provider    String   // "POLCARD", "STRIPE"
  status      String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, CANCELLED
  metadata    Json?
  response    Json?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([orderId])
  @@index([status])
}

// ============================================================
// OFFLINE SYNC (idempotency + audit)
// ============================================================

model SyncLog {
  id            String   @id @default(cuid())
  operationId   String   @unique
  table         String
  localId       String
  serverId      String?
  serverVersion Int?
  success       Boolean
  processedAt   DateTime @default(now())

  @@index([operationId])
  @@index([processedAt])
  @@index([localId, table])
}

// P-RECEIPT-FIX: Audit trail dla błędów fiskalizacji — nigdy nie gubimy dowodów
model ReceiptErrorLog {
  id           String   @id @default(cuid())
  orderId      String
  paymentId    String?
  errorMessage String
  retryCount   Int      @default(0)
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
  @@index([resolvedAt])
}

// FISCAL-EVENTS: Kolejka zdarzeń fiskalnych (receipt, correction, refund, daily report)
model FiscalEvent {
  id           String   @id @default(cuid())
  orderId      String?
  paymentId    String?
  type         String   // RECEIPT_PRINTED | RECEIPT_CANCELLED | REFUND_PRINTED | DAILY_REPORT
  status       String   @default("PENDING") // PENDING | SENT | OK | ERROR
  payloadJson  Json?
  fiscalNumber String?
  errorMessage String?
  retryCount   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orderId, createdAt])
  @@index([status, createdAt])
  @@index([type, status])
}
